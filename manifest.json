{
  "manifest_version": 3,
  "name": "Dreem 图片下载",
  "version": "0.8.2",
  "description": "下载 dreem-world studio 角色页/场景页的原图与变体裁剪图，并可将页面文字设定（Identity/Personality 等）导出为 Markdown，支持打包或分张下载。",
  "permissions": ["scripting"],
  "host_permissions": ["https://studio.dreem-world.ai/*", "https://*.cloudfront.net/*", "https://raw.githubusercontent.com/*"],
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Dreem 图片下载",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "32": "src/icons/icon-32.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://studio.dreem-world.ai/worlds/*"],
      "js": ["src/lib/core.js", "src/lib/jszip.min.js", "src/page-config.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
